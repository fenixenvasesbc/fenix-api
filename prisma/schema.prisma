generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SALES
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(SALES)
  isActive     Boolean  @default(true)

  // Un SALES puede tener (como máximo) 1 cuenta.
  // ADMIN normalmente lo tendrá null.
  accountId String?  @unique
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model Account {
  id        String @id @default(uuid())
  name      String

  // Identificadores YCloud para multi-cuenta
  wabaId    String
  phoneE164 String // ejemplo: +34645730616

  // Relación 1-1 inversa con User (SALES)
  user User?

  // Una cuenta puede tener múltiples leads o ninguno
  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unicidad: una cuenta se identifica por wabaId + teléfono
  @@unique([wabaId, phoneE164])

  @@index([phoneE164])
  @@index([wabaId])
}

model Lead {
  id        String @id @default(uuid())

  // Datos mínimos recomendados (ajústalo a tu CRM)
  name      String?
  phoneE164 String?
  email     String?

  // Lead asociado a una cuenta (0..N por cuenta)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([phoneE164])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}