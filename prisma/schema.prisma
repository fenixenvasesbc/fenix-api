generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SALES
}

enum LeadStatus {
  NEW          // creado/confirmado al aceptar el primer envío
  RESPONDED    // cuando llega el primer inbound (de cualquier tipo)
  // luego: WAITING_SKETCH, IN_PRODUCTION, CLOSED_WON, etc.
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageType {
  TEMPLATE
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  UNKNOWN
}

enum MessageStatus {
  ACCEPTED     // lo que llega en envío: "accepted"
  SENT
  DELIVERED
  READ
  FAILED
  UNKNOWN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(SALES)
  isActive     Boolean  @default(true)

  // Un SALES puede tener (como máximo) 1 cuenta.
  // ADMIN normalmente lo tendrá null.
  accountId String?  @unique
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model Account {
  id        String @id @default(uuid())
  name      String

  // Identificadores YCloud para multi-cuenta
  wabaId    String
  phoneE164 String // ejemplo: +34645730616

  // Relación 1-1 inversa con User (SALES)
  user User?

  // Una cuenta puede tener múltiples leads o ninguno
  leads Lead[]
  // Una cuenta puede tener múltiples mensajes o ninguno
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unicidad: una cuenta se identifica por wabaId + teléfono
  @@unique([wabaId, phoneE164])

  @@index([phoneE164])
  @@index([wabaId])
}

model Lead {
  id        String @id @default(uuid())
  name      String?
  phoneE164 String
  email     String?
  status    LeadStatus @default(NEW)
  firstOutboundAt DateTime? // se setea cuando aceptan el 1er envío
  firstInboundAt  DateTime? // se setea cuando llega el 1er inbound
  firstOutboundTemplateName String? // para métrica #1, se setea con el template del 1er envío

  // Lead asociado a una cuenta (0..N por cuenta)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([phoneE164])
  @@index([email])
  @@index([firstInboundAt])
  @@index([accountId, firstOutboundAt])
  @@index([firstOutboundTemplateName])
  @@unique([accountId, phoneE164])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Message {
  id String @id @default(uuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  leadId String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  direction MessageDirection
  type      MessageType

  // IDs de YCloud/WhatsApp para correlación
  ycloudMessageId String? // outbound: response.id, inbound: whatsappInboundMessage.id
  wamid           String? // wamid.HBg...
  contextWamid    String? // inbound.context.id (si viene)

  // Campaña/plantilla para métrica #1
  templateName   String? // outbound.template.name
  templateLang   String? // outbound.template.language.code
  pricingCategory String? // outbound.pricingCategory (opcional)
  // coste por mensaje (lo que te manda YCloud)
  totalPrice      Decimal? @db.Decimal(12, 6)
  currency         String?  // outbound.pricingCurrency
  status MessageStatus @default(UNKNOWN)

  // timestamps del proveedor
  providerCreateTime DateTime? // outbound.createTime o inbound.createTime
  providerUpdateTime DateTime? // outbound.updateTime
  providerSendTime   DateTime? // inbound.sendTime (si aplica)

  // contenido (opcional ahora, útil luego)
  textBody String? // inbound.text.body si type=TEXT
  mediaUrl String? // para image/video/document (si luego lo necesitas)

  // debug/auditoría
  rawPayload Json? // guardas el payload entero por si mañana necesitas campos

  createdAt DateTime @default(now())

  @@index([accountId, leadId, direction, createdAt])
  @@index([accountId, direction, type, providerCreateTime])
  @@index([accountId, templateName, providerCreateTime])
  @@index([templateName])
  @@index([wamid])
  @@unique([accountId, ycloudMessageId])
}